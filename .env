# Server port
PORT=5000

# Email Server SMTP Configurations
# For Gmail, keep EMAIL_HOST as smtp.gmail.com and EMAIL_PORT as 587.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Sender email credentials
# EMAIL_USER should be the Gmail address sending the emails.
# EMAIL_PASS must be an App Password (not your account password).
EMAIL_USER=your-sending-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Recipient email (where you want to receive the messages)
EMAIL_RECEIVER=kq.malik400@gmail.com, medinshealthcare@gmail.com
